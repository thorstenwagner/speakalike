{
  "name": "speakalike",
  "version": "1.0.0",
  "description": "SpeakAlike - Text-to-Speech mit Voice Cloning",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "author": "SpeakAlike",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.speakalike.app",
    "productName": "SpeakAlike",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "files": [
      "**/*",
      "!**/*.py",
      "!**/__pycache__"
    ]
  }
}
