{
  "name": "speakalike",
  "version": "1.0.0",
  "description": "SpeakAlike - Text-to-Speech mit Voice Cloning",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "author": "SpeakAlike",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.speakalike.app",
    "productName": "SpeakAlike",
    "directories": {
      "output": "../dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icons/icon.ico",
      "uninstallerIcon": "icons/icon.ico",
      "installerHeaderIcon": "icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      {
        "from": "../dist/backend",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "../voice_models",
        "to": "voice_models",
        "filter": ["*.pt", ".last_model", ".last_tts_model"]
      }
    ],
    "files": [
      "**/*",
      "!**/*.py",
      "!**/__pycache__"
    ]
  },
  "dependencies": {
    "franc": "^5.0.0"
  }
}
